  <%# 入力フォーム %>
  <section class="entry-card">
    <p class="entry-card-title">結果を記録する</p>
    <%= form_with model: @new_score, data: { turbo_frame: "scores_list" } do |f| %>
      <div class="form-row">
        <div class="form-group full-width">
          <%= f.label :test_date, "日付" %>
          <%= f.date_field :test_date %>
        </div>

        <div class="form-group full-width">
          <%= f.label :homework_id, "宿題" %>
          <%= f.collection_select :homework_id, @homeworks, :id, :title,
                { prompt: "宿題を選んでください" } %>
        </div>

        <div class="form-group">
          <%= f.label :vocabulary_score, "単語テスト" %>
          <%= f.number_field :vocabulary_score, placeholder: "例: 10", min: 0, max: 10 %>
        </div>

          <div class="form-group">
          <%= f.label :sentence_score, "文テスト" %>
          <%= f.number_field :sentence_score, placeholder: "例: 2", min: 0, max: 2 %>
        </div>
        
        <div class="form-group align-bottom">
          <%= f.submit "記録する" %>
        </div>
      </div>

      <% if @new_score.errors.any? %>
        <ul class="error-list">
          <% @new_score.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      <% end %>
    <% end %>
  </section>  
