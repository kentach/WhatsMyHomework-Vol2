<% content_for :title, t('.title') %>

<div class="homework-show">
  <%# ── ヘッダー ── %>
  <header class="homework-show-header">
    <div class="homework-show-header-inner">
      <div class="show-top">
        <span class="hero-badge"><%= @homework.classroom.name %></span>
        <div class="show-top-actions">
        </div>
      </div>
      <h1 class="show-title"><%= @homework.title %></h1>
      <div class="show-header-meta">
        <div class="test-period-inline">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <%= @homework.test_start_date.to_date %> 〜 <%= @homework.test_end_date.to_date %>
        </div>
      </div>
    </div>
  </header>

  <%# ── ボディ ── %>
  <div class="homework-show-body">

    <%# タスク一覧 %>
    <div class="homework-show-task-list">
      <div class="homework-show-task-list-header">
        <h3>宿題リスト</h3>
        <span class="homework-showtask-list-count"><%= @tasks.size %> タスク</span>
      </div>

      <div class="homework-show-test-info">
        <ul>
          <li>📌 授業前に宿題を必ずチェックしよう！</li>
        </ul>
      </div>

      <% @tasks.each do |task| %>
        <div id="task-<%= task.id %>" class="homework-show-task-item">
          <label class="homework-show-task-check-wrap">
            <div id="homework-show-completed-button-for-task-<%= task.id %>">
            </div>
            <span class="homework-show-task-name">
              <i class="fa-solid fa-square-check"></i>
              <%= task.name %>
            </span>
          </label>
        </div>
      <% end %>
    </div>

    <%= link_to homeworks_path, class: "back-link" do %>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      一覧に戻る
    <% end %>

  </div>
</div>

<%= render 'shared/navigation_bar' %>