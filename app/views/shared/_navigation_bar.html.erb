<section id="footer" class="footer-bottom">
  <div class="tab-menu">

    <%= link_to homeworks_path,
        class: "tab-item #{current_page?(homeworks_path) ? 'active' : ''}" do %>
      <i class="fa-regular fa-house"></i>
      <span>宿題一覧</span>
    <% end %>

    <%= link_to tasks_path,
        class: "tab-item #{current_page?(tasks_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-user-graduate"></i>
      <span>マイタスク</span>
    <% end %>

    <%= link_to vocabulary_tests_path,
        class: "tab-item #{current_page?(vocabulary_tests_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-chart-line"></i>
      <span>単語テストスコア</span>
    <% end %>

    <%= link_to notifications_path,
        class: "tab-item #{current_page?(notifications_path) ? 'active' : ''}" do %>
        <i class="fa-regular fa-envelope"></i>
      <span>お知らせ</span>
    <% end %>
  </div>
</section>