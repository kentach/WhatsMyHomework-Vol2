<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">クラス一覧</h3>
        <%= link_to "新規作成", new_admin_classroom_path, class: "btn btn-primary btn-sm" %>
      </div>
      <div class="card-body">
        <table class="table table-bordered table-hover">
          <thead>
            <tr>
              <th>クラス名</th>
              <th>クラス(英語表記)</th>
              <th>編集</th>
              <th>削除</th>
            </tr>
          </thead>
          <tbody>
            <% @classrooms.each do |classroom| %>
              <tr>
                <td><%= classroom.eiken_level %></td>
                <td><%= classroom.name %></td>
                <td>
                  <%= link_to "編集", edit_admin_homework_path(classroom), class: "btn btn-sm btn-warning" %>
                </td>
                <td>
                  <%= button_to "削除", admin_classroom_path(classroom), method: :delete, data: { turbo_confirm: "削除しますか？" }, class: "btn btn-sm btn-danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>