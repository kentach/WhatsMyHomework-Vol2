<div class="card-body">
  <%= form_with model: [:admin, @notification] do |f| %>

      <%# エラーメッセージ %>
      <%= render "admin/notifications/error_message"%>

      <%# タイトル %>
      <div class="mb-3">
        <%= f.label :title, "タイトル", class: "form-label fw-bold" %>
        <%= f.text_field :title,
              autofocus: true,
              placeholder: "例：クラス名・対象学年 / 月・Week / タイトルの順で書く。",
              class: "form-control" %>
        <p class="mt-2 mb-1 text-muted small">
          ⚠️ 受講者に表示されるタイトルです。内容がわかるよう簡潔に記入してください。
        </p>
        <p class="mt-0 mb-1 text-muted small">
          💡 例）中高生 ◯月 月例単語テスト ◯/◯ ~ ◯/◯ 実施
        </p>
        <p class="mt-0 mb-1 text-muted small">
          💡 例）小学生高学年5級 Week◯ 宿題の修正
        </p>
      </div>

      <%# 本文 %>
      <div class="mb-3">
        <%= f.label :content, "本文", class: "form-label fw-bold" %>
        <%= f.text_area :content,
              rows: 8,
              placeholder: "通知の詳細内容を入力してください。",
              class: "form-control" %>
      </div>

      <%# 通知種別 %>
      <div class="mb-3">
        <%= f.label :notification_type, "通知の種別", class: "form-label fw-bold" %>
        <%= f.select :notification_type,
              [
                ["宿題の訂正",     "homework_correction"],
                ["月例単語テスト", "monthly_vocab_test"],
                ["イベント",       "event"],
                ["英検結果",       "eiken_result"],
                ["お知らせ",       "information"],
                ["その他",         "others"]
              ],
              { prompt: "種別を選択" },
              class: "form-select" %>
        <p class="mt-2 text-muted small">
          ⚠️ 種別を正しく選択してください。
        </p>
      </div>

      <div class="mb-3">
        <%= f.label :target_type, "送信対象", class: "form-label fw-bold" %>
        <%= f.select :target_type,
              [
                ["全クラス",   "all_classes"],
                ["クラス別",   "specific_class"]
              ],
              {},
              class: "form-select",
              id: "target_type_select" %>
      </div>

      <%# クラス選択（クラス別のみ表示） %>
      <div class="mb-3" id="classroom_select_wrapper">
        <%= f.label :classroom_ids, "送信先クラス（複数選択可）", class: "form-label fw-bold" %>
        <%= f.collection_check_boxes :classroom_ids, Classroom.all, :id, :name do |b| %>
          <div class="form-check">
            <%= b.check_box class: "form-check-input" %>
            <%= b.label class: "form-check-label" %>
          </div>
        <% end %>
        <p class="mt-2 text-muted small">
          ⚠️「クラス別」を選択した場合は必ず1つ以上チェックしてください。
        </p>
      </div>

      <%# ステータス %>
      <div class="mb-3">
        <%= f.label :status, "ステータス", class: "form-label fw-bold" %>
        <%= f.select :status,
              [ ["下書き", "draft"], 
                ["公開", "published"], 
              ],
              {},
              class: "form-select",
              id: "status_select" %>
      </div>

      <%# 送信ボタン %>
      <div class="d-flex gap-2 mt-4">
        <%= f.submit "作成する", class: "btn btn-primary" %>
        <%= link_to "キャンセル", admin_notifications_path, class: "btn btn-secondary" %>
      </div>

  <% end %>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    const targetTypeSelect   = document.getElementById("target_type_select");
    const classroomWrapper   = document.getElementById("classroom_select_wrapper");
    const statusSelect       = document.getElementById("status_select");

    function toggleClassroom() {
      classroomWrapper.style.display =
        targetTypeSelect.value === "specific_class" ? "block" : "none";
    }

    targetTypeSelect.addEventListener("change", toggleClassroom);
    // 初期表示
    toggleClassroom();
  });
</script>
