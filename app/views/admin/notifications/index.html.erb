<%= render "admin/notifications/header" %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">
          <i class="fa-solid fa-bell"></i> 通知一覧
        </h3>
        <%= link_to "+ 新しい通知を作成", new_admin_notification_path, class: "btn btn-danger" %>
      </div>

      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>タイトル</th>
              <th>種別</th>
              <th>対象</th>
              <th>ステータス</th>
              <th>作成日時</th>
              <th>最終更新</th>
              <th>作成者</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @notifications.each do |notification| %>
              <tr>
                <td>
                  <strong><%= truncate(notification.title, length: 15, omission: "…")%></strong>
                </td>

                <td>
                  <% case notification.notification_type %>
                  <% when "homework_correction" %>
                    <span class="badge bg-primary">
                      <i class="fa-solid fa-bullhorn"></i> 宿題訂正
                    </span>
                  <% when "monthly_vocab_test" %>
                    <span class="badge bg-warning text-dark">
                      <i class="fa-solid fa-book"></i> 月例単語テスト
                    </span>
                  <% when "others" %>
                    <span class="badge bg-info">
                      <i class="fa-solid fa-chalkboard-user"></i> その他
                    </span>
                  <% when "event" %>
                    <span class="badge bg-success">
                      <i class="fa-solid fa-calendar"></i> イベント
                    </span>
                  <% when "eiken_result" %>
                    <span class="badge bg-info">
                      <i class="fa-solid fa-star"></i> 英検結果
                    </span>
                  <% when "information" %>
                    <span class="badge bg-secondary">
                      <i class="fa-solid fa-circle-info"></i> お知らせ
                    </span>
                  <% when "others" %>
                    <span class="badge bg-light text-dark">
                      <i class="fa-solid fa-chalkboard-user"></i> その他
                    </span>
                  <% else %>
                    <span class="badge bg-secondary">未設定</span>
                  <% end %>
                </td>

                <td>
                  <% if notification.all_classes? %>
                    <span class="text-muted">
                      <i class="fa-solid fa-users"></i> 全クラス
                    </span>
                  <% else %>
                    <span>
                      <i class="fa-solid fa-user-group"></i>
                      <%= truncate(notification.classrooms.map(&:name).join("、").presence, length: 20, omission: "…") || "未設定" %>
                    </span>
                  <% end %>
                </td>


                <td>
                  <% case notification.status %>
                    <% when "published" %>
                      <span class="badge bg-success">公開</span>
                    <% when "draft" %>
                      <span class="badge bg-warning text-dark">下書き</span>
                  <% end %>
                </td>

                <td>
                  <%= notification.created_at.strftime("%Y/%m/%d %H:%M") %>
                    <br>
                    <small class="text-muted">
                      （<%= %w(日 月 火 水 木 金 土)[notification.created_at.wday] %>）
                    </small>
                </td>

                <td>
                  <%= notification.updated_at.strftime("%Y/%m/%d %H:%M") %>
                  <br>
                  <small class="text-muted">
                    （<%= %w(日 月 火 水 木 金 土)[notification.updated_at.wday] %>）
                  </small>
                </td>

                <td><%= notification.user&.name %></td>

                <td>
                  <%= link_to "編集", edit_admin_notification_path(notification),
                        class: "btn btn-sm mb-1 btn-warning" %>

                  <%= button_to "削除", admin_notification_path(notification),
                        method: :delete,
                        data: { turbo_confirm: "この通知を削除しますか？" },
                        class: "btn btn-sm btn-danger" %>
                </td>
              </tr>
            <% end %>

            <% if @notifications.empty? %>
              <tr>
                <td colspan="8" class="text-center text-muted py-4">
                  通知がありません。「+ 新しい通知を作成」から追加してください。
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @notifications.respond_to?(:current_page) %>
        <div class="card-footer">
          <%= paginate @notifications %>
        </div>
      <% end %>
    </div>
  </div>
</div>
