<div class="container mb-5 pt-2">
  <h1><%= title %></h1>
  <div class="row">
    <div class="col-md-8">
      <%= form_with model: [:admin, @user] do |f| %>
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <% @user.errors.full_messages.each do |msg| %>
              <p><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :name, User.human_attribute_name(:name), class: "form-label" %>
          <%= f.text_field :name, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :student_id, "生徒ID", class: "form-label" %>
          <%= f.text_field :student_id, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :classroom_id, "クラス", class: "form-label" %>
          <%= f.collection_select :classroom_id, Classroom.all, :id, :eiken_level, { include_blank: "選択してください" }, class: "form-select" %>
        </div>

        <div class="mb-3">
          <%= f.label :role, User.human_attribute_name(:role), class: "form-label" %>
          <%= f.select :role, User.roles.map { |key, value| [t("enums.user.role.#{key}"), key] }, { include_blank: "選択してください" }, class: "form-select" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, User.human_attribute_name(:password), class: "form-label" %>
          <%= f.password_field :password, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, User.human_attribute_name(:password_confirmation), class: "form-label" %>
          <%= f.password_field :password_confirmation, class: "form-control" %>
        </div>

        <%= f.submit "保存", class: "btn btn-primary" %>
        <%= link_to "キャンセル", admin_users_path, class: "btn btn-secondary ms-2" %>
      <% end %>
    </div>
  </div>
</div>