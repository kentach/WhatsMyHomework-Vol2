<div class="tab-panel" id="panel-complete">
    <% complete_groups = @homeworks.select { |homework| homework.tasks.any? { |t| !current_user.completed?(t) } } %>
    <% if complete_groups.any? %>
      <% complete_groups.each do |homework| %>
      <% tasks_to_show = homework.tasks.reject { |t| current_user.completed?(t) } %>
        <div class="homework-group">
          <div class="homework-group-header">
            <div class="homework-group-meta">
              <span class="homework-group-badge"><%= homework.classroom.name %></span>
              <span class="homework-group-period"><%= I18n.l(homework.test_end_date, format: '%m/%d') %>まで</span>
            </div>
            <%= link_to homework_path(homework), class: "homework-group-title" do %>
              <%= homework.title %>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            <% end %>
          </div>
          <div class="homework-group-tasks">
            <% tasks_to_show.each do |task| %>
              <div id="task-<%= task.id %>" class="task-item completed">
                <label class="task-check-wrap">
                  <div id="completed-button-for-task-<%= task.id %>">
                  
                  </div>
                  <span class="task-name"><%= task.name %></span>
                </label>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="my-tasks-empty">
        <p class="my-tasks-empty-icon">📭</p>
        <p class="my-tasks-empty-text">完了済みのタスクはありません</p>
      </div>
    <% end %>
  </div>